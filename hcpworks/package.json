{
  "name": "hcpworks",
  "displayName": "HCPWorks",
  "description": "This extension displays HCP chart.",
  "version": "0.0.12",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "publisher": "in0ho1no",
  "icon": "resources/icon/icon_128px_light.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/in0ho1no/HCPWorks"
  },
  "activationEvents": [
    "onLanguage:hcp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "menus": {
      "editor/title": [
        {
          "when": "hcpworks.webviewActive",
          "command": "hcpworks.refreshPreview",
          "group": "navigation"
        },
        {
          "when": "hcpworks.webviewActive",
          "command": "hcpworks.savePreview",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "when": "view == hcpworks-View",
          "command": "hcpworks.listingModule",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "hcp",
        "extensions": [
          ".hcp"
        ],
        "aliases": [
          "HCP"
        ]
      }
    ],
    "commands": [
      {
        "command": "hcpworks.listingModule",
        "title": "HCPWorks: Listing Modules",
        "when": "editorLangId == hcp",
        "icon": {
          "light": "resources/icon/refresh-light.svg",
          "dark": "resources/icon/refresh-dark.svg"
        }
      },
      {
        "command": "hcpworks.refreshPreview",
        "title": "HCPWorks: Refresh Preview to Current Module",
        "icon": {
          "light": "resources/icon/refresh-light.svg",
          "dark": "resources/icon/refresh-dark.svg"
        }
      },
      {
        "command": "hcpworks.savePreview",
        "title": "HCPWorks: Save Preview to Current Folder",
        "icon": {
          "light": "resources/icon/save-light.svg",
          "dark": "resources/icon/save-dark.svg"
        }
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "hcpworks-View",
          "name": "HCP Module List",
          "icon": "resources/icon/icon_16px_light.svg"
        },
        {
          "id": "hcpworks-numberInputView",
          "type": "webview",
          "name": "HCP Preview Level",
          "icon": "resources/icon/icon_16px_light.svg"
        }
      ]
    },
    "keybindings": [
      {
        "command": "hcpworks.listingModule",
        "key": "ctrl+alt+q",
        "mac": "cmd+alt+q",
        "when": "editorTextFocus"
      }
    ],
    "grammars": [
      {
        "language": "hcp",
        "scopeName": "source.hcp",
        "path": "./syntaxes/hcp.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "HCPWorks Configuration",
      "properties": {
        "hcpworks.SvgBgColor": {
          "type": "string",
          "default": "FFFFFF",
          "description": "HCP Preview SVG background color."
        },
        "hcpworks.WireColorTable": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "000000",
            "FF0000",
            "00FF00",
            "0000FF",
            "FFFF00",
            "800080",
            "FFA500",
            "40E0D0"
          ],
          "description": "HCP Preview wire color table."
        }
      }
    },
    "configurationDefaults": {
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "keyword.control.module.hcp",
            "settings": {
              "foreground": "#4dabf7"
            }
          },
          {
            "scope": "keyword.control.table.hcp",
            "settings": {
              "foreground": "#ffce93"
            }
          },
          {
            "scope": "keyword.control.kind.hcp",
            "settings": {
              "foreground": "#7f7bb1"
            }
          },
          {
            "scope": "keyword.control.scope.hcp",
            "settings": {
              "foreground": "#7f7bb1"
            }
          },
          {
            "scope": "keyword.control.data.hcp",
            "settings": {
              "foreground": "#ffb92d"
            }
          },
          {
            "scope": "keyword.control.fork.hcp",
            "settings": {
              "foreground": "#a64aca"
            }
          },
          {
            "scope": "keyword.control.branch.hcp",
            "settings": {
              "foreground": "#cc5de8"
            }
          },
          {
            "scope": "keyword.control.true.hcp",
            "settings": {
              "foreground": "#40c057"
            }
          },
          {
            "scope": "keyword.control.false.hcp",
            "settings": {
              "foreground": "#fa5252"
            }
          },
          {
            "scope": "keyword.control.repeat.hcp",
            "settings": {
              "foreground": "#20c997"
            }
          },
          {
            "scope": "keyword.control.mod.hcp",
            "settings": {
              "foreground": "#339af0"
            }
          },
          {
            "scope": "keyword.control.return.hcp",
            "settings": {
              "foreground": "#f783ac"
            }
          },
          {
            "scope": "keyword.control.in.hcp",
            "settings": {
              "foreground": "#ffa94d"
            }
          },
          {
            "scope": "keyword.control.out.hcp",
            "settings": {
              "foreground": "#e67700"
            }
          },
          {
            "scope": "keyword.control.drop.hcp",
            "settings": {
              "foreground": "#9c5202"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:prod",
    "compile": "webpack",
    "watch": "webpack --watch",
    "build:prod": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "npm run compile-tests && mocha --ui tdd --require src/test/__mocks__/setup.js 'out/test/**/*.test.js'",
    "prepare-readme": "cp ./README.md ../README.md",
    "prepare-readme-en": "cp ./README.en.md ../README.en.md",
    "package-ext": "vsce package --no-yarn"
  },
  "overrides": {
    "serialize-javascript": ">=7.0.5",
    "fast-uri": "3.1.2"
  },
  "devDependencies": {
    "@types/encoding-japanese": "^2.2.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "26.x",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^10.4.1",
    "mocha-junit-reporter": "^2.2.1",
    "ts-loader": "^9.6.1",
    "typescript": "^6.0.3",
    "webpack": "^5.99.7",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "encoding-japanese": "^2.2.0"
  }
}
