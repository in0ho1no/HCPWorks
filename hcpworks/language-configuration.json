{
  "$schema": "vscode://schemas/language-configuration",
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["（", "）"],
    ["［", "］"],
    ["｛", "｝"],
    ["「", "」"],
    ["『", "』"],
    ["【", "】"],
    ["《", "》"],
    ["〈", "〉"],
    ["<", ">"],
    ["＜", "＞"],
    ["〔", "〕"],
    ["〖", "〗"],
    ["〘", "〙"]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"],
    ["（", "）"],
    ["［", "］"],
    ["｛", "｝"],
    ["「", "」"],
    ["『", "』"],
    ["【", "】"],
    ["《", "》"],
    ["〈", "〉"],
    ["<", ">"],
    ["＜", "＞"],
    ["〔", "〕"],
    ["〖", "〗"],
    ["〘", "〙"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "[", "close": "]" },
    { "open": "{", "close": "}" },
    { "open": "\"", "close": "\"", "notIn": ["string"] },
    { "open": "'", "close": "'", "notIn": ["string"] },
    { "open": "`", "close": "`" },
    { "open": "（", "close": "）" },
    { "open": "［", "close": "］" },
    { "open": "｛", "close": "｝" },
    { "open": "「", "close": "」" },
    { "open": "『", "close": "』" },
    { "open": "【", "close": "】" },
    { "open": "《", "close": "》" },
    { "open": "〈", "close": "〉" },
    { "open": "<", "close": ">" },
    { "open": "＜", "close": "＞" },
    { "open": "〔", "close": "〕" },
    { "open": "〖", "close": "〗" },
    { "open": "〘", "close": "〙" }
  ]
}
